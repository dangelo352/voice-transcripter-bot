# Discord Voice Transcripter Bot
# Rename this file to .env and fill in your bot token
#
# Required:
DISCORD_BOT_TOKEN=your_bot_token_here
#
# Optional (uncomment to override defaults):
# WHISPER_MODEL_SIZE=medium   # tiny, base, small, medium, large-v3 (default: medium)
# WHISPER_DEVICE=cpu          # cpu or cuda (default: cpu)
# WHISPER_COMPUTE_TYPE=int8   # int8, int8_float16, float16 (default: int8)